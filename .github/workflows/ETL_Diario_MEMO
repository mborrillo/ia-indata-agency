name: ETL Diario MEMO

on:
  schedule:
    - cron: '0 8 * * 1-5'
  workflow_dispatch:

jobs:
  etl:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalar dependencias
        run: pip install -r projects/energia-mercados/requirements.txt

      - name: Ejecutar ETL
        env:
          NEON_DATABASE_URL: ${{ secrets.MEMO_NEON_URL }}
        run: |
          cd projects/energia-mercados
          python -m etl.run_daily
